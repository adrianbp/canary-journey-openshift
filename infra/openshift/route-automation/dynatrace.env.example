# Dynatrace API access
DT_BASE_URL="https://<your-environment-id>.live.dynatrace.com"
DT_API_TOKEN="dt0c01...."

# Metric selectors (edit to match your Dynatrace entities/dimensions)
# Example server error rate (%), averaged over timeframe
DT_ERROR_METRIC_SELECTOR="builtin:service.errors.server.rate:avg"

# Example p95 latency in milliseconds
DT_LATENCY_METRIC_SELECTOR="builtin:service.response.time:percentile(95)"

# Optional: constrain metrics to specific entities
# Example: type(SERVICE),entityId("SERVICE-1234567890ABCDEF")
DT_ENTITY_SELECTOR=""

# Time window for each evaluation
DT_FROM="now-5m"
DT_TO="now"

# Gate thresholds
DT_MAX_ERROR_RATE_PERCENT="1.0"
DT_MAX_P95_MS="500"

# Behavior when no data is returned: true|false
DT_ALLOW_NO_DATA="false"
