aws_region      = "us-west-2"
cluster_name    = "canary-eks-stg"
cluster_version = "1.30"

vpc_cidr        = "10.91.0.0/16"
private_subnets = ["10.91.1.0/24", "10.91.2.0/24", "10.91.3.0/24"]
public_subnets  = ["10.91.101.0/24", "10.91.102.0/24", "10.91.103.0/24"]

enable_nat_gateway = true
single_nat_gateway = true

node_instance_types = ["m5.xlarge"]
node_min_size       = 3
node_max_size       = 8
node_desired_size   = 3

observability_namespace = "canary-observability"
service_account_name    = "canary-status-reader"
deploy_status_api       = true
status_api_image        = "ghcr.io/company/canary-status-api:latest"
status_api_replicas     = 2

tags = {
  environment = "stg"
  owner       = "platform-team"
}
