aws_region      = "us-west-2"
cluster_name    = "canary-eks-dev"
cluster_version = "1.30"

vpc_cidr        = "10.90.0.0/16"
private_subnets = ["10.90.1.0/24", "10.90.2.0/24", "10.90.3.0/24"]
public_subnets  = ["10.90.101.0/24", "10.90.102.0/24", "10.90.103.0/24"]

enable_nat_gateway = true
single_nat_gateway = true

node_instance_types = ["m5.large"]
node_min_size       = 2
node_max_size       = 5
node_desired_size   = 3

observability_namespace = "canary-observability"
service_account_name    = "canary-status-reader"
deploy_status_api       = true
status_api_image        = "ghcr.io/company/canary-status-api:latest"
status_api_replicas     = 1

tags = {
  environment = "dev"
  owner       = "platform-team"
}
